{
  "name": "vault-bridge-plugin",
  "version": "0.2.0",
  "description": "Obsidian plugin for Vault Bridge — syncs your vault to Cloudflare R2",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "plugin", "vault-bridge", "claude", "r2"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.7.0",
    "typescript": "^5.7.0"
  }
}
